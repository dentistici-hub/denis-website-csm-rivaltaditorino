---
/**
 * ContentAboutProse — text-only extended about block for CSM.
 *
 * The shared ContentAbout variant is shaped around a chef/founder portrait.
 * CSM has no founder photo and asks for "room to breathe" around the
 * infissi-carcerari differentiator and the P.IVA trust line, so this variant
 * renders display headline + lead paragraph + supporting body, nothing else.
 */
interface Pair {
  label: string;
  value: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  lead?: string;
  body?: string;
  facts?: Pair[];
  sectionId?: string;
}

const {
  eyebrow = 'L\u2019officina',
  title,
  lead,
  body,
  facts = [],
  sectionId = 'chi-siamo',
} = Astro.props;
---

<section class="aboutprose section" id={sectionId} aria-labelledby="aboutprose-title">
  <div class="container">
    <div class="aboutprose__grid">
      <div class="aboutprose__main">
        {eyebrow && (
          <p class="aboutprose__eyebrow" data-animate>
            <span class="aboutprose__eyebrow-line" aria-hidden="true"></span>
            <span>{eyebrow}</span>
          </p>
        )}
        {title && <h2 class="aboutprose__title" id="aboutprose-title" data-animate>{title}</h2>}
        {lead && <p class="aboutprose__lead" data-animate>{lead}</p>}
        {body && <p class="aboutprose__body" data-animate>{body}</p>}
      </div>

      {facts.length > 0 && (
        <aside class="aboutprose__facts" aria-label="Dati aziendali" data-animate>
          <dl>
            {facts.map((f) => (
              <div class="aboutprose__fact">
                <dt>{f.label}</dt>
                <dd>{f.value}</dd>
              </div>
            ))}
          </dl>
        </aside>
      )}
    </div>
  </div>
</section>

<style>
  .aboutprose {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .aboutprose__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 900px) {
    .aboutprose__grid {
      grid-template-columns: 1.6fr 1fr;
      column-gap: var(--space-2xl);
      align-items: start;
    }
  }

  .aboutprose__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-sm);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .aboutprose__eyebrow-line {
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    display: block;
  }

  .aboutprose__title {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    line-height: 1.0;
    text-transform: uppercase;
    color: var(--color-fg);
    margin-bottom: var(--space-lg);
    max-width: 22ch;
  }

  .aboutprose__lead {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--color-fg);
    margin-bottom: var(--space-md);
    max-width: 62ch;
  }

  .aboutprose__body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: 1.7;
    color: var(--color-fg);
    opacity: 0.82;
    max-width: 62ch;
  }

  .aboutprose__facts {
    border-top: 2px solid var(--color-fg);
    padding-top: var(--space-md);
  }

  .aboutprose__facts dl {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin: 0;
  }

  .aboutprose__fact {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .aboutprose__fact:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .aboutprose__fact dt {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
  }

  .aboutprose__fact dd {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-fg);
    line-height: 1.4;
  }
</style>
