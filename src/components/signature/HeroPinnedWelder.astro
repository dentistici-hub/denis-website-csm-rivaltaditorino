---
/**
 * HeroPinnedWelder — the signature move for CSM.
 *
 * Rule: primary content (headline, subtitle, CTA, anchor stat) is LEGIBLE
 * FROM FIRST PAINT at progress=0. Scroll does NOT hide or reveal the core
 * message — scroll scrubs ATMOSPHERE.
 *
 * Shape: HeroSplit-style two-column hero (text left, welder photo right)
 * nested INSIDE a ScrollPinSection. The `--progress` CSS variable drives:
 *   - photo scale 1.00 -> 1.04 and brightness 1.0 -> 0.7 (subtle, gives depth)
 *   - photo scrim opacity 0 -> 0.35 (darkens photo into a frame)
 *   - accent measurement rule draws across under the eyebrow (left-to-right)
 *   - headline letter-spacing tightens from 0 to -0.015em (breath of craft)
 *
 * Reduced motion: the ScrollPinSection primitive force-sets --progress=1, so
 * every child lands at its final state immediately (no animation).
 */
import ScrollPinSection from '../motion-primitives/ScrollPinSection.astro';

interface Props {
  headline: string;
  subtitle: string;
  ctaLabel: string;
  ctaHref: string;
  photoSrc: string;
  photoWebp?: string;
  photoAlt: string;
  anchorText?: string;
  anchorSublabel?: string;
}

const {
  headline,
  subtitle,
  ctaLabel,
  ctaHref,
  photoSrc,
  photoWebp,
  photoAlt,
  anchorText = '50+',
  anchorSublabel = 'Anni di ferro battuto',
} = Astro.props;

// Prefix asset paths with Astro's base URL so assets resolve under GH Pages sub-path deploys.
const withBase = (p: string | undefined): string | undefined => {
  if (!p) return p;
  if (/^(https?:\/\/|data:)/.test(p)) return p;
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return p.startsWith('/') ? `${base}${p}` : `${base}/${p}`;
};
---

<ScrollPinSection
  distance="120vh"
  start="top top"
  scrub={0.8}
  anticipatePin={1}
  class="hero-welder"
  id="hero"
>
  <div class="hero-welder__grid">
    <div class="hero-welder__text">
      <p class="hero-welder__eyebrow">
        <span class="hero-welder__eyebrow-rule" aria-hidden="true"></span>
        <span>Carpenteria metallica</span>
        <span class="hero-welder__eyebrow-sep" aria-hidden="true">·</span>
        <span>Rivalta di Torino</span>
      </p>
      <h1 class="hero-welder__headline">{headline}</h1>
      <p class="hero-welder__subtitle">{subtitle}</p>
      <div class="hero-welder__actions">
        <a href={ctaHref} class="hero-welder__cta">{ctaLabel}</a>
      </div>
      <div class="hero-welder__anchor" aria-hidden="false">
        <span class="hero-welder__anchor-num stat">{anchorText}</span>
        <span class="hero-welder__anchor-label">{anchorSublabel}</span>
      </div>
    </div>

    <div class="hero-welder__media">
      <picture>
        {photoWebp && <source srcset={withBase(photoWebp)} type="image/webp" />}
        <img
          class="hero-welder__photo"
          src={withBase(photoSrc)}
          alt={photoAlt}
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </picture>
      <div class="hero-welder__photo-scrim" aria-hidden="true"></div>
    </div>
  </div>
</ScrollPinSection>

<style>
  .hero-welder {
    background: var(--color-bg);
  }

  .hero-welder :global(.pin-section__inner) {
    min-height: 100vh;
    padding-top: calc(72px + var(--space-lg));
    padding-bottom: var(--space-lg);
  }

  .hero-welder__grid {
    position: relative;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--gutter);
    gap: var(--space-xl);
    align-items: stretch;
  }

  @media (min-width: 960px) {
    .hero-welder__grid {
      grid-template-columns: 1.15fr 1fr;
      gap: clamp(var(--space-lg), 4vw, var(--space-2xl));
    }
  }

  .hero-welder__text {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: var(--space-xl);
    min-height: 72vh;
  }

  .hero-welder__eyebrow {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-sm);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.7em;
    row-gap: 0.25em;
  }

  .hero-welder__eyebrow-rule {
    display: inline-block;
    width: clamp(1.5rem, 6vw, 4rem);
    height: 1px;
    /* The rule grows as scroll progresses — a measurement line being drawn. */
    background: currentColor;
    transform-origin: left center;
    transform: scaleX(calc(0.2 + var(--progress, 0) * 0.8));
    transition: transform 80ms linear;
    margin-right: 0.2em;
  }

  .hero-welder__eyebrow-sep {
    opacity: 0.5;
  }

  /* Tighten on narrow viewports so the line doesn't wrap awkwardly. */
  @media (max-width: 520px) {
    .hero-welder__eyebrow {
      letter-spacing: 0.12em;
      font-size: 0.72rem;
    }
  }

  .hero-welder__headline {
    font-family: var(--font-display);
    font-size: var(--text-display);
    line-height: 0.9;
    text-transform: uppercase;
    /* Letter-spacing tightens subtly as user scrolls — a breath of craft without hiding the word. */
    letter-spacing: calc(var(--progress, 0) * -0.015em);
    color: var(--color-fg);
    max-width: 14ch;
    margin-bottom: var(--space-md);
    transition: letter-spacing 80ms linear;
  }

  .hero-welder__subtitle {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: var(--text-lg);
    line-height: 1.5;
    color: var(--color-fg);
    max-width: 48ch;
    margin-bottom: var(--space-lg);
  }

  .hero-welder__actions {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .hero-welder__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    padding: 0.95rem 2.2rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
    text-decoration: none;
    border: none;
    transition: background var(--duration-fast);
  }

  .hero-welder__cta::before {
    content: '\260E';
    font-size: 1.1em;
    line-height: 1;
  }

  .hero-welder__cta:hover {
    background: var(--color-accent-hover);
  }

  .hero-welder__anchor {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border-top: 2px solid var(--color-fg);
    padding-top: var(--space-sm);
    max-width: 18rem;
  }

  .hero-welder__anchor-num {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    color: var(--color-fg);
  }

  .hero-welder__anchor-label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-fg);
    opacity: 0.75;
    letter-spacing: 0.02em;
  }

  .hero-welder__media {
    position: relative;
    overflow: hidden;
    min-height: 72vh;
    background: #111;
  }

  @media (max-width: 959px) {
    .hero-welder__media {
      aspect-ratio: 4 / 5;
      min-height: auto;
    }
  }

  .hero-welder__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Subtle pin-driven scale + brightness. Numbers kept gentle so the
       welder face never turns to silhouette — the human is the subject. */
    transform: scale(calc(1 + var(--progress, 0) * 0.04));
    filter: brightness(calc(1 - var(--progress, 0) * 0.3));
    will-change: transform, filter;
    transition: transform 60ms linear, filter 60ms linear;
  }

  .hero-welder__photo-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(18, 18, 18, 0) 50%,
      rgba(18, 18, 18, calc(var(--progress, 0) * 0.35)) 100%
    );
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-welder__headline,
    .hero-welder__subtitle,
    .hero-welder__actions,
    .hero-welder__photo,
    .hero-welder__photo-scrim {
      transform: none !important;
      opacity: 1 !important;
      filter: none !important;
    }
  }
</style>
